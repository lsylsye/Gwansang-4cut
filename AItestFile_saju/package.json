{
  "name": "face-reading-rag",
  "version": "1.0.0",
  "description": "관상 분석 RAG CLI - 프롬프트 엔지니어링 테스트",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/main.js",
    "dev": "ts-node src/main.ts",
    "saju": "node dist/saju_main.js",
    "saju:dev": "npx ts-node src/saju_main.ts",
    "index": "npx ts-node src/indexer.ts index",
    "index:force": "npx ts-node src/indexer.ts index --force",
    "index:status": "npx ts-node src/indexer.ts status"
  },
  "keywords": [
    "rag",
    "face-reading",
    "gpt-5-mini"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@xenova/transformers": "^2.17.2",
    "lunisolar": "^2.6.0",
    "redis": "^5.10.0",
    "sharp": "^0.33.5"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
